root ::= document
document ::= header assignment+ footer?
header ::= "BEGIN"
assignment ::= identifier "=" (literal | tuple | "computed")
tuple ::= "(" literal ("," literal)* ")"
literal ::= number | ga-qualified | "quoted"
number ::= digit+
digit ::= "0" | "1" | "2"
identifier ::= "identifier"
footer ::= "END"
padding ::= ""
ga-qualified ::= "qualified"