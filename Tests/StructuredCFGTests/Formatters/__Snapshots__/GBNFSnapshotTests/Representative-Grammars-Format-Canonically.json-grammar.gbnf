root ::= object | array
sign ::= ("+" | "-")?
fraction ::= ("." [0-9]+)?
exponent ::= ([eE] sign [0-9]+)?
hex_digit ::= [a-fA-F0-9]
escape ::= ["\/bfnrt] | "u" hex_digit{4}
string_characters ::= "\"" | [^\x0-\x1f"\x5c] string_characters | "\\" escape string_characters
string ::= "\"" string_characters
number ::= "0" fraction exponent | [1-9] [0-9]* fraction exponent | "-" "0" fraction exponent | "-" [1-9] [0-9]* fraction exponent
value ::= object | array | string | number | "true" | "false" | "null"
member ::= string [ \n\t]* ":" [ \n\t]* value
members ::= member ([ \n\t]* "," [ \n\t]* member)*
object ::= "{" [ \n\t]* (members [ \n\t]*)? "}"
elements ::= value ([ \n\t]* "," [ \n\t]* value)*
array ::= "[" [ \n\t]* (elements [ \n\t]*)? "]"